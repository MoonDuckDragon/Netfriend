[legacy_telnet_switches]
Switch-2 ansible_host=10.254.254.12
Switch-6 ansible_host=10.254.254.16
Switch-8 ansible_host=10.254.254.18

[legacy_telnet_switches:vars]
ansible_connection=local
ansible_user=ansible
ansible_password=1234

[modern_ssh_switches]
Switch-4 ansible_host=10.254.254.14
Switch-5 ansible_host=10.254.254.15

[modern_ssh_switches:vars]
ansible_connection=network_cli
ansible_network_os=ios
ansible_user=ansible
ansible_password=1234
ansible_become=yes
ansible_become_method=enable
ansible_become_password=1234
ansible_network_cli_ssh_type=paramiko
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o KexAlgorithms=+diffie-hellman-group14-sha1 -o HostKeyAlgorithms=+ssh-rsa'
